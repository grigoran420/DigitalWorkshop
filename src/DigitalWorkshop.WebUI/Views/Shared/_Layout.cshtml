<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Цифровой Цех</title>
    
    <!-- Подключение современных шрифтов и иконок -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100 bg-dark text-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-uppercase tracking-wide" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cpu-fill me-2 text-info"></i>Цифровой Цех
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link active" aria-current="page" asp-area="" asp-controller="TechnologyProcesses" asp-action="Index">
                                <i class="bi bi-diagram-3-fill me-1"></i> ТП Конструктор
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-lock-fill me-1"></i> Аудит
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="modulesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-grid-3x3-gap-fill me-1"></i> Модули
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark" aria-labelledby="modulesDropdown">
                                <li><a class="dropdown-item disabled" href="#"><i class="bi bi-box-seam me-2"></i>WMS (Склад)</a></li>
                                <li><a class="dropdown-item disabled" href="#"><i class="bi bi-gear-wide-connected me-2"></i>MES (Сборка)</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item disabled" href="#"><i class="bi bi-check2-square me-2"></i>ОТК (Контроль)</a></li>
                            </ul>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center text-muted small font-monospace">
                        <span class="me-3"><i class="bi bi-circle-fill text-success me-1" style="font-size: 0.5rem;"></i>ONLINE</span>
                        <span id="clock">--:--:--</span>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-grow-1 py-4">
        <div class="container-fluid px-4">
            @RenderBody()
        </div>
    </main>

    <footer class="footer mt-auto py-3 bg-dark border-top border-secondary">
        <div class="container-fluid px-4 text-center text-muted small font-monospace">
            <span>© @DateTime.Now.Year ЕПК "Цифровой Цех"</span>
            <span class="mx-2">|</span>
            <span>Build 24.05.06</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
            setInterval(() => {
                const now = new Date();
                document.getElementById('clock').textContent = now.toLocaleTimeString('ru-RU');
            }, 1000);
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>